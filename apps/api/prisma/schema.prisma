generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PARENT
  TUTOR
}

enum TuitionCaseStatus {
  OPEN
  MATCHED
  CLOSED
}

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  passwordHash   String
  role           UserRole
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  tutorProfile   TutorProfile?
  ownedCases     TuitionCase[]    @relation("CaseOwner")
  invitations    CaseInvitation[] @relation("TutorInvitations")
  uploadedDocs   Document[]       @relation("UploadedDocuments")

  @@index([role])
  @@index([createdAt])
}

model TutorProfile {
  id             String     @id @default(cuid())
  userId         String     @unique
  displayName    String
  qualifications String
  experiences    String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents      Document[]

  @@index([displayName])
  @@index([createdAt])
}

model TuitionCase {
  id            String             @id @default(cuid())
  ownerId       String
  title         String
  subject       String
  level         String
  location      String
  budgetPerHour Decimal            @db.Decimal(10, 2)
  status        TuitionCaseStatus  @default(OPEN)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  owner         User               @relation("CaseOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  invitations   CaseInvitation[]
  documents     Document[]

  @@index([ownerId, createdAt])
  @@index([status, createdAt])
  @@index([subject, level])
  @@index([location])
}

model CaseInvitation {
  id        String      @id @default(cuid())
  caseId    String
  tutorId   String
  createdAt DateTime    @default(now())
  revokedAt DateTime?
  case      TuitionCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  tutor     User        @relation("TutorInvitations", fields: [tutorId], references: [id], onDelete: Cascade)

  @@unique([caseId, tutorId])
  @@index([caseId, revokedAt])
  @@index([tutorId, revokedAt, createdAt])
}

model Document {
  id               String        @id @default(cuid())
  caseId           String?
  tutorProfileId   String?
  uploadedById     String
  originalFilename String
  storageKey       String        @unique
  mimeType         String
  size             Int
  createdAt        DateTime      @default(now())
  case             TuitionCase?  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  tutorProfile     TutorProfile? @relation(fields: [tutorProfileId], references: [id], onDelete: Cascade)
  uploadedBy       User          @relation("UploadedDocuments", fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([caseId, createdAt])
  @@index([tutorProfileId, createdAt])
  @@index([uploadedById, createdAt])
}
