{
  "name": "minerva-tutor-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @minerva/api dev",
    "dev:api": "pnpm --filter @minerva/api dev",
    "dev:web": "pnpm --filter @minerva/web dev",
    "build": "pnpm --filter @minerva/api build",
    "build:web": "pnpm --filter @minerva/web build",
    "test": "pnpm --filter @minerva/api test",
    "lint": "pnpm --filter @minerva/api lint",
    "lint:web": "pnpm --filter @minerva/web lint",
    "typecheck:web": "pnpm --filter @minerva/web typecheck",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "prisma:generate": "pnpm --filter @minerva/api prisma:generate",
    "prisma:migrate": "pnpm --filter @minerva/api prisma:migrate",
    "seed": "pnpm --filter @minerva/api seed"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
